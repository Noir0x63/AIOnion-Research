# Venice AI Configuration
VENICE_API_KEY=your_venice_api_key_here
VENICE_MODEL=deepseek-v4-flash

# Tor Proxy Configuration (Use 9150 for Tor Browser, 9050 for system Tor service)
# Note: socks5h ensures DNS resolution happens on the proxy (remote DNS), preventing DNS leaks.
TOR_PROXY_URL=socks5h://127.0.0.1:9150
